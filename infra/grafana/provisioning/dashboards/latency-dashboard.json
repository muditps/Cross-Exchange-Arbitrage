{
  "title": "Arbitrage Platform — Latency Dashboard",
  "uid": "arbitrage-latency-v1",
  "description": "Pipeline latency percentiles per stage. Powered by HdrHistogram recorded at T0-T9 timestamps through the Kafka pipeline.",
  "tags": ["arbitrage", "latency", "performance"],
  "editable": true,
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "graphTooltip": 1,
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Detection p99 (ms)",
      "description": "DETECTION_PROCESSING p99 — Redis MGET + cross-exchange comparison. Target: <15ms.",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_latency_nanos{stage=\"detection_processing\",percentile=\"p99\"} / 1000000",
          "legendFormat": "Detection p99",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Detection p50 (ms)",
      "description": "DETECTION_PROCESSING p50 — median hot-path latency.",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_latency_nanos{stage=\"detection_processing\",percentile=\"p50\"} / 1000000",
          "legendFormat": "Detection p50",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "End-to-End p99 (ms)",
      "description": "END_TO_END p99 — WebSocket receive (T1) to opportunity published (T9). Includes two Kafka transit hops.",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_latency_nanos{stage=\"end_to_end\",percentile=\"p99\"} / 1000000",
          "legendFormat": "E2E p99",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "End-to-End p50 (ms)",
      "description": "END_TO_END p50 — median full-pipeline latency.",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_latency_nanos{stage=\"end_to_end\",percentile=\"p50\"} / 1000000",
          "legendFormat": "E2E p50",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 150 }
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "type": "bargauge",
      "title": "Pipeline Latency per Stage — Current p50 & p99",
      "description": "Horizontal bars showing current p50 (median) and p99 (tail) latency for each pipeline stage. Stages: connector→normaliser transit, normalisation processing, normaliser→detector transit, detection processing, publish overhead.",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_latency_nanos{percentile=\"p50\",stage!=\"end_to_end\"} / 1000000",
          "legendFormat": "p50 · {{stage}}",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_latency_nanos{percentile=\"p99\",stage!=\"end_to_end\"} / 1000000",
          "legendFormat": "p99 · {{stage}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "lcd",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "End-to-End Latency Over Time",
      "description": "p50 and p99 of full pipeline latency (T1→T9). Updated every 10s from HdrHistogram snapshots. High p99 spikes indicate GC pauses or Kafka consumer rebalancing.",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_latency_nanos{stage=\"end_to_end\",percentile=\"p50\"} / 1000000",
          "legendFormat": "E2E p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_latency_nanos{stage=\"end_to_end\",percentile=\"p99\"} / 1000000",
          "legendFormat": "E2E p99"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "E2E p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "E2E p50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Detection Processing Latency Over Time",
      "description": "p50, p95, p99 of DETECTION_PROCESSING (T6→T8): Redis MGET + cross-exchange comparison. This is the hot-path latency — directly proportional to trading opportunity capture speed.",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_latency_nanos{stage=\"detection_processing\",percentile=\"p50\"} / 1000000",
          "legendFormat": "Detection p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_latency_nanos{stage=\"detection_processing\",percentile=\"p95\"} / 1000000",
          "legendFormat": "Detection p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_latency_nanos{stage=\"detection_processing\",percentile=\"p99\"} / 1000000",
          "legendFormat": "Detection p99"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Detection p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Detection p50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Detection p95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          }
        ]
      }
    }

  ]
}
